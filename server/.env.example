# ═══════════════════════════════════════════════════════════════════════════
# EduTrak Server Environment Configuration - EXAMPLE
# Copy this file to .env and fill in your actual values
# ═══════════════════════════════════════════════════════════════════════════

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/edutrak_db

# ─── Authentication & JWT ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# API Keys for service-to-service authentication
API_KEYS=dev-key-1,dev-key-2

# ─── CORS & Origins ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=*,http://localhost:3000,http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ─── File Upload ──────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── Email Configuration (SMTP) ────────────────────────────────────────────────
# Option 1: Gmail with App Password
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Option 2: Mailtrap (recommended for testing)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-inbox-user
SMTP_PASS=your-mailtrap-inbox-password

# ─── Frontend URL ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Optional: Monitoring ─────────────────────────────────────────────────────
# SENTRY_DSN=
# DATADOG_API_KEY=

# ─── Optional: Payment Processing ─────────────────────────────────────────────
# STRIPE_SECRET_KEY=
# STRIPE_PUBLIC_KEY=

# ─── Optional: Cloud Storage ──────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=
