generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                     String                  @id @default(uuid())
  name                   String
  slug                   String                  @unique
  type                   String                  @default("SCHOOL")
  isActive               Boolean                 @default(true)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  invoices               FeeInvoice[]
  feePayments            FeePayment[]
  feeRefunds             FeeRefund[]
  lateFeesConfigs        LateFeesConfig[]
  paymentProviderConfigs PaymentProviderConfig[]
  school                 School?
  WebhookEmissions       WebhookEmission[]
  webhookLogs            WebhookLog[]

  @@index([slug])
  @@index([type])
}

model School {
  id                    String                 @id @default(uuid())
  tenantId              String?                @unique
  name                  String
  registrationNo        String?                @unique
  type                  SchoolType
  county                String
  subCounty             String?
  ward                  String?
  knecCode              String?                @unique
  kemisCode             String?                @unique
  phone                 String?
  email                 String?
  address               String?
  ownership             Ownership
  boardingStatus        BoardingStatus
  gender                SchoolGender
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  academicYears         AcademicYear[]
  assessmentDefinitions AssessmentDefinition[]
  assessmentResults     AssessmentResult[]
  assessmentWeights     AssessmentWeight[]
  auditLogs             AuditLog[]
  billingAccount        BillingAccount?
  billingInvoices       BillingInvoice[]
  billingPayments       BillingPayment[]
  classes               Class[]
  classSubjects         ClassSubject[]
  documentTemplates     DocumentTemplate[]
  feeInvoices           FeeInvoice[]
  feePayments           FeePayment[]
  feeRefunds            FeeRefund[]
  feeStructures         FeeStructure[]
  tenant                Tenant?                @relation(fields: [tenantId], references: [id])
  brandingConfig        SchoolBrandingConfig?
  streams               Stream[]
  students              Student[]
  studentClasses        StudentClass[]
  studentClassSubjects  StudentClassSubject[]
  subjectOfferings      SubjectOffering[]
  subscriptions         TenantSubscription[]
  terms                 Term[]
  timetables            Timetable[]
  usageMetrics          UsageMetric[]
  users                 User[]

  @@index([county])
  @@index([type])
}

model SchoolBrandingConfig {
  id                String   @id @default(uuid())
  schoolId          String   @unique
  logoUrl           String?
  miniLogoUrl       String?
  appDisplayName    String?
  faviconUrl        String?
  primaryColor      String?
  secondaryColor    String?
  accentColor       String?
  fontFamily        String?
  borderRadiusScale String?
  density           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model Plan {
  id              String               @id @default(uuid())
  key             String               @unique
  name            String
  description     String?
  priceMinor      Int
  currency        String               @default("KES")
  billingInterval BillingInterval
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  features        PlanFeature[]
  subscriptions   TenantSubscription[]
}

model PlanFeature {
  id         String    @id @default(uuid())
  planId     String
  featureKey String
  limitType  LimitType @default(BOOLEAN)
  limitValue Int?
  enabled    Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  plan       Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureKey])
  @@index([featureKey])
}

model TenantSubscription {
  id                 String             @id @default(uuid())
  schoolId           String
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  startsAt           DateTime
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEndsAt        DateTime?
  graceEndsAt        DateTime?
  cancelAt           DateTime?
  canceledAt         DateTime?
  lastBillingDate    DateTime?
  renewalCount       Int                @default(0)
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  invoices           BillingInvoice[]
  payments           BillingPayment[]
  plan               Plan               @relation(fields: [planId], references: [id])
  school             School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([planId])
}

model BillingAccount {
  id                String   @id @default(uuid())
  schoolId          String   @unique
  legalName         String
  email             String?
  phone             String?
  taxId             String?
  country           String?
  city              String?
  addressLine1      String?
  addressLine2      String?
  preferredCurrency String   @default("KES")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model BillingInvoice {
  id              String               @id @default(uuid())
  schoolId        String
  subscriptionId  String
  invoiceNumber   String               @unique
  status          BillingInvoiceStatus @default(OPEN)
  subtotalMinor   Int
  taxMinor        Int                  @default(0)
  totalMinor      Int
  amountPaidMinor Int                  @default(0)
  currency        String               @default("KES")
  issuedAt        DateTime             @default(now())
  dueAt           DateTime
  paidAt          DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  school          School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscription    TenantSubscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  payments        BillingPayment[]

  @@index([schoolId, status])
  @@index([subscriptionId])
}

model BillingPayment {
  id                String               @id @default(uuid())
  schoolId          String
  subscriptionId    String
  billingInvoiceId  String?
  provider          String
  providerReference String?
  amountMinor       Int
  currency          String               @default("KES")
  status            BillingPaymentStatus @default(PENDING)
  paidAt            DateTime?
  metadata          Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  invoice           BillingInvoice?      @relation(fields: [billingInvoiceId], references: [id])
  school            School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subscription      TenantSubscription   @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([billingInvoiceId])
}

model UsageMetric {
  id          String   @id @default(uuid())
  schoolId    String
  metricKey   String
  periodStart DateTime
  periodEnd   DateTime
  usedUnits   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, metricKey, periodStart, periodEnd])
  @@index([schoolId, metricKey])
}

model DocumentTemplate {
  id              String                @id @default(uuid())
  schoolId        String
  name            String
  scope           DocumentTemplateScope
  status          TemplateStatus        @default(DRAFT)
  createdByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  school          School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  versions        TemplateVersion[]

  @@index([schoolId, scope])
}

model TemplateVersion {
  id            String           @id @default(uuid())
  templateId    String
  versionNumber Int
  htmlContent   String
  cssContent    String?
  schemaJson    Json?
  publishedAt   DateTime?
  createdAt     DateTime         @default(now())
  template      DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, versionNumber])
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  password   String
  firstName  String
  lastName   String
  middleName String?
  phone      String?
  idNumber   String?     @unique
  role       Role        @default(TEACHER)
  schoolId   String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  auditLogs  AuditLog[]  @relation("ActorAuditLogs")
  feeRefunds FeeRefund[]
  guardian   Guardian?
  student    Student?
  teacher    Teacher?
  school     School?     @relation(fields: [schoolId], references: [id])

  @@index([role])
  @@index([schoolId])
}

model Student {
  id                 String                @id @default(uuid())
  admissionNo        String                @unique
  upiNumber          String?               @unique
  kemisUpi           String?               @unique
  firstName          String
  middleName         String?
  lastName           String
  gender             Gender
  dob                DateTime?
  birthCertNo        String?
  nationality        String                @default("Kenyan")
  county             String?
  subCounty          String?
  hasSpecialNeeds    Boolean               @default(false)
  specialNeedsType   String?
  medicalCondition   String?
  allergies          String?
  schoolId           String?
  userId             String?               @unique
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  assessmentResults  AssessmentResult[]
  feeInvoices        FeeInvoice[]
  feePayments        FeePayment[]
  feeRefunds         FeeRefund[]
  school             School?               @relation(fields: [schoolId], references: [id])
  user               User?                 @relation(fields: [userId], references: [id])
  enrollments        StudentClass[]
  subjectEnrollments StudentClassSubject[]
  guardians          StudentGuardian[]

  @@index([schoolId])
  @@index([schoolId, admissionNo])
  @@index([schoolId, gender])
}

model Guardian {
  id           String            @id @default(uuid())
  userId       String            @unique
  relationship String
  occupation   String?
  employer     String?
  workPhone    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User              @relation(fields: [userId], references: [id])
  students     StudentGuardian[]
}

model StudentGuardian {
  id           String    @id @default(uuid())
  studentId    String
  guardianId   String
  relationship String?
  isPrimary    Boolean   @default(false)
  isVerified   Boolean   @default(false)
  verifiedAt   DateTime?
  verifiedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  guardian     Guardian  @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([studentId])
  @@index([guardianId])
}

model Teacher {
  id                String             @id @default(uuid())
  userId            String             @unique
  tscNumber         String             @unique
  employeeNumber    String             @unique
  employmentType    EmploymentType
  qualification     String?
  specialization    String?
  dateJoined        DateTime?          @default(now())
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assessmentsGraded AssessmentResult[] @relation("AssessedBy")
  classTeacherOf    Class[]            @relation("ClassTeacher")
  teachingSubjects  ClassSubject[]     @relation("TeacherClassSubjects")
  periodSlots       PeriodSlot[]       @relation("TeacherPeriodSlots")
  streamTeacherOf   Stream[]           @relation("StreamTeacher")
  user              User               @relation(fields: [userId], references: [id])
}

model Sequence {
  id              String   @id @default(uuid())
  key             String   @unique
  type            String
  schoolId        String?
  year            Int?
  currentValue    Int      @default(0)
  prefix          String?
  lastGeneratedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([schoolId])
  @@index([year])
  @@index([type, schoolId, year])
}

model AcademicYear {
  id                    String                 @id @default(uuid())
  year                  Int
  startDate             DateTime
  endDate               DateTime
  isActive              Boolean                @default(false)
  schoolId              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  school                School?                @relation(fields: [schoolId], references: [id])
  assessmentDefinitions AssessmentDefinition[]
  classes               Class[]
  classSubjects         ClassSubject[]         @relation("AcademicYearClassSubjects")
  feeInvoices           FeeInvoice[]
  feeStructures         FeeStructure[]
  studentClasses        StudentClass[]
  terms                 Term[]
  timetables            Timetable[]

  @@unique([year, schoolId])
  @@index([isActive])
  @@index([schoolId])
}

model Term {
  id                    String                 @id @default(uuid())
  name                  TermName
  termNumber            Int
  startDate             DateTime
  endDate               DateTime
  academicYearId        String
  schoolId              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  AssessmentDefinitions AssessmentDefinition[]
  assessmentWeights     AssessmentWeight[]
  classSubjects         ClassSubject[]         @relation("TermClassSubjects")
  feeInvoices           FeeInvoice[]
  feeStructures         FeeStructure[]
  academicYear          AcademicYear           @relation(fields: [academicYearId], references: [id])
  school                School?                @relation(fields: [schoolId], references: [id])
  timetables            Timetable[]

  @@unique([academicYearId, termNumber])
  @@index([academicYearId])
  @@index([academicYearId, schoolId])
  @@index([schoolId])
}

model Class {
  id               String         @id @default(uuid())
  name             String
  level            String
  curriculum       Curriculum
  academicYearId   String
  schoolId         String
  classTeacherId   String?
  pathway          Pathway?
  isFinal          Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id])
  classTeacher     Teacher?       @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  school           School         @relation(fields: [schoolId], references: [id])
  subjects         ClassSubject[]
  streams          Stream[]
  students         StudentClass[]
  promotedStudents StudentClass[] @relation("Promotion")
  timetables       Timetable[]

  @@unique([name, academicYearId, schoolId])
  @@index([curriculum])
  @@index([schoolId])
  @@index([schoolId, academicYearId])
  @@index([schoolId, level])
}

model Stream {
  id              String         @id @default(uuid())
  name            String
  capacity        Int?
  classId         String
  schoolId        String
  streamTeacherId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  classSubjects   ClassSubject[]
  class           Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  school          School         @relation(fields: [schoolId], references: [id])
  streamTeacher   Teacher?       @relation("StreamTeacher", fields: [streamTeacherId], references: [id])
  students        StudentClass[]
  timetables      Timetable[]

  @@unique([classId, name])
  @@index([classId])
}

model Subject {
  id           String            @id @default(uuid())
  name         String
  code         String            @unique
  category     SubjectCategory
  learningArea LearningArea?
  subjectGroup SubjectGroup?
  curriculum   Curriculum[]
  description  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  classLinks   ClassSubject[]
  strands      Strand[]
  offerings    SubjectOffering[]

  @@index([code])
  @@index([category])
}

model SubjectOffering {
  id        String  @id @default(uuid())
  schoolId  String
  subjectId String
  isActive  Boolean @default(true)
  school    School  @relation(fields: [schoolId], references: [id])
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([schoolId, subjectId])
  @@index([schoolId])
}

model ClassSubject {
  id                 String                 @id @default(uuid())
  classId            String
  streamId           String?
  subjectId          String
  teacherId          String?
  termId             String
  academicYearId     String
  subjectCategory    SubjectCategory
  schoolId           String?
  assessments        AssessmentDefinition[]
  assessmentWeights  AssessmentWeight[]
  academicYear       AcademicYear           @relation("AcademicYearClassSubjects", fields: [academicYearId], references: [id])
  class              Class                  @relation(fields: [classId], references: [id])
  school             School?                @relation(fields: [schoolId], references: [id])
  stream             Stream?                @relation(fields: [streamId], references: [id])
  subject            Subject                @relation(fields: [subjectId], references: [id])
  teacherProfile     Teacher?               @relation("TeacherClassSubjects", fields: [teacherId], references: [id])
  term               Term                   @relation("TermClassSubjects", fields: [termId], references: [id])
  strands            ClassSubjectStrand[]
  periodSlots        PeriodSlot[]
  studentEnrollments StudentClassSubject[]

  @@unique([classId, streamId, subjectId, termId, academicYearId])
  @@index([teacherId])
  @@index([schoolId, academicYearId])
  @@index([schoolId, classId])
  @@index([schoolId, termId])
}

model Strand {
  id                    String                 @id @default(uuid())
  name                  String
  description           String?
  subjectId             String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  assessmentDefinitions AssessmentDefinition[]
  classSubjects         ClassSubjectStrand[]
  subject               Subject                @relation(fields: [subjectId], references: [id])
}

model ClassSubjectStrand {
  id             String       @id @default(uuid())
  classSubjectId String
  strandId       String
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id])
  strand         Strand       @relation(fields: [strandId], references: [id])

  @@unique([classSubjectId, strandId])
}

model StudentClass {
  id                 String                @id @default(uuid())
  studentId          String
  classId            String
  streamId           String?
  academicYearId     String
  schoolId           String?
  status             EnrollmentStatus      @default(ACTIVE)
  promotedToId       String?
  promotionDate      DateTime?
  transferredFrom    String?
  transferDate       DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  academicYear       AcademicYear          @relation(fields: [academicYearId], references: [id])
  class              Class                 @relation(fields: [classId], references: [id])
  promotedTo         Class?                @relation("Promotion", fields: [promotedToId], references: [id])
  school             School?               @relation(fields: [schoolId], references: [id])
  stream             Stream?               @relation(fields: [streamId], references: [id])
  student            Student               @relation(fields: [studentId], references: [id])
  subjectEnrollments StudentClassSubject[]

  @@index([studentId])
  @@index([classId])
  @@index([status])
  @@index([schoolId, academicYearId])
  @@index([schoolId, classId])
}

model StudentClassSubject {
  id             String                  @id @default(uuid())
  studentId      String
  classSubjectId String
  enrollmentId   String
  schoolId       String?
  enrolledAt     DateTime                @default(now())
  status         SubjectEnrollmentStatus @default(ACTIVE)
  droppedAt      DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  classSubject   ClassSubject            @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  enrollment     StudentClass            @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  school         School?                 @relation(fields: [schoolId], references: [id])
  student        Student                 @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, classSubjectId, enrollmentId])
  @@index([studentId])
  @@index([classSubjectId])
  @@index([enrollmentId])
  @@index([schoolId])
  @@index([status])
}

model AssessmentWeight {
  id             String         @id @default(uuid())
  assessmentType AssessmentType
  termId         String
  classSubjectId String
  weight         Float
  schoolId       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  classSubject   ClassSubject   @relation(fields: [classSubjectId], references: [id])
  school         School?        @relation(fields: [schoolId], references: [id])
  term           Term           @relation(fields: [termId], references: [id])

  @@unique([assessmentType, termId, classSubjectId])
  @@index([termId])
  @@index([classSubjectId])
  @@index([schoolId])
}

model AssessmentDefinition {
  id                 String             @id @default(uuid())
  name               String
  type               AssessmentType
  status             AssessmentStatus   @default(DRAFT)
  maxMarks           Float?
  termId             String
  classSubjectId     String
  schoolId           String?
  academicYearId     String?
  strandId           String?
  createdById        String?
  publishedAt        DateTime?
  resultsPublishedAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  academicYear       AcademicYear?      @relation(fields: [academicYearId], references: [id])
  classSubject       ClassSubject       @relation(fields: [classSubjectId], references: [id])
  school             School?            @relation(fields: [schoolId], references: [id])
  strand             Strand?            @relation(fields: [strandId], references: [id])
  term               Term               @relation(fields: [termId], references: [id])
  results            AssessmentResult[]

  @@index([schoolId])
  @@index([academicYearId])
  @@index([termId])
  @@index([classSubjectId])
  @@index([strandId])
  @@index([status])
}

model AssessmentResult {
  id              String               @id @default(uuid())
  studentId       String
  assessmentDefId String
  schoolId        String?
  numericValue    Float?
  grade           String?
  competencyLevel CompetencyLevel?
  comment         String?
  assessedById    String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  assessedBy      Teacher              @relation("AssessedBy", fields: [assessedById], references: [id])
  assessmentDef   AssessmentDefinition @relation(fields: [assessmentDefId], references: [id])
  school          School?              @relation(fields: [schoolId], references: [id])
  student         Student              @relation(fields: [studentId], references: [id])

  @@unique([studentId, assessmentDefId])
  @@index([schoolId])
  @@index([studentId])
  @@index([assessmentDefId])
  @@index([assessedById])
}

model Timetable {
  id             String       @id @default(uuid())
  schoolId       String
  academicYearId String
  termId         String?
  classId        String
  streamId       String?
  name           String
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  periods        Period[]
  slots          PeriodSlot[]
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])
  class          Class        @relation(fields: [classId], references: [id])
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stream         Stream?      @relation(fields: [streamId], references: [id])
  term           Term?        @relation(fields: [termId], references: [id])

  @@index([schoolId])
  @@index([schoolId, academicYearId])
  @@index([classId])
  @@index([isActive])
}

model Period {
  id          String       @id @default(uuid())
  timetableId String
  name        String
  startTime   String
  endTime     String
  orderIndex  Int
  isBreak     Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  timetable   Timetable    @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  slots       PeriodSlot[]

  @@unique([timetableId, orderIndex])
  @@index([timetableId])
}

model PeriodSlot {
  id             String        @id @default(uuid())
  timetableId    String
  periodId       String
  dayOfWeek      DayOfWeek
  classSubjectId String?
  teacherId      String?
  room           String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  classSubject   ClassSubject? @relation(fields: [classSubjectId], references: [id])
  period         Period        @relation(fields: [periodId], references: [id], onDelete: Cascade)
  teacher        Teacher?      @relation("TeacherPeriodSlots", fields: [teacherId], references: [id])
  timetable      Timetable     @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@unique([timetableId, periodId, dayOfWeek])
  @@index([timetableId])
  @@index([teacherId])
  @@index([classSubjectId])
}

model AuditLog {
  id         String   @id @default(uuid())
  schoolId   String?
  actorId    String?
  actorRole  String?
  action     String
  entityType String
  entityId   String?
  entityName String?
  details    String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  actor      User?    @relation("ActorAuditLogs", fields: [actorId], references: [id])
  school     School?  @relation(fields: [schoolId], references: [id])

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
}

model FeeStructure {
  id             String          @id @default(uuid())
  name           String
  description    String?
  academicYearId String
  termId         String?
  classLevel     String?
  boardingStatus BoardingStatus?
  currency       String          @default("KES")
  isActive       Boolean         @default(true)
  schoolId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  invoices       FeeInvoice[]
  items          FeeItem[]
  academicYear   AcademicYear    @relation(fields: [academicYearId], references: [id])
  school         School          @relation(fields: [schoolId], references: [id])
  term           Term?           @relation(fields: [termId], references: [id])

  @@index([schoolId])
  @@index([schoolId, academicYearId])
  @@index([isActive])
}

model FeeItem {
  id             String           @id @default(uuid())
  feeStructureId String
  name           String
  category       FeeCategory
  amount         Decimal          @db.Decimal(12, 2)
  isOptional     Boolean          @default(false)
  description    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  invoiceItems   FeeInvoiceItem[]
  feeStructure   FeeStructure     @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@index([feeStructureId])
  @@index([category])
}

model FeeInvoice {
  id             String            @id @default(uuid())
  tenantId       String?
  invoiceNo      String            @unique
  studentId      String
  feeStructureId String
  academicYearId String
  termId         String?
  schoolId       String
  status         InvoiceStatus     @default(UNPAID)
  totalAmount    Decimal           @db.Decimal(12, 2)
  discountAmount Decimal           @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal           @default(0) @db.Decimal(12, 2)
  balanceAmount  Decimal           @db.Decimal(12, 2)
  dueDate        DateTime?
  notes          String?
  issuedAt       DateTime          @default(now())
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  academicYear   AcademicYear      @relation(fields: [academicYearId], references: [id])
  feeStructure   FeeStructure      @relation(fields: [feeStructureId], references: [id])
  school         School            @relation(fields: [schoolId], references: [id])
  student        Student           @relation(fields: [studentId], references: [id])
  tenant         Tenant?           @relation(fields: [tenantId], references: [id])
  term           Term?             @relation(fields: [termId], references: [id])
  items          FeeInvoiceItem[]
  payments       FeePayment[]
  feeRefunds     FeeRefund[]
  paymentPlan    PaymentPlan?
  reminders      PaymentReminder[]

  @@index([schoolId])
  @@index([studentId])
  @@index([schoolId, academicYearId])
  @@index([schoolId, termId])
  @@index([status])
  @@index([invoiceNo])
}

model FeeInvoiceItem {
  id         String      @id @default(uuid())
  invoiceId  String
  feeItemId  String
  name       String
  category   FeeCategory
  amount     Decimal     @db.Decimal(12, 2)
  isWaived   Boolean     @default(false)
  waiverNote String?
  createdAt  DateTime    @default(now())
  feeItem    FeeItem     @relation(fields: [feeItemId], references: [id])
  invoice    FeeInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model FeePayment {
  id             String        @id @default(uuid())
  tenantId       String?
  receiptNo      String        @unique
  invoiceId      String
  studentId      String
  schoolId       String
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod
  status         PaymentStatus @default(COMPLETED)
  transactionRef String?
  mpesaCode      String?
  bankName       String?
  chequeNo       String?
  paidAt         DateTime      @default(now())
  reversedAt     DateTime?
  reversalReason String?
  receivedById   String?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  invoice        FeeInvoice    @relation(fields: [invoiceId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id])
  student        Student       @relation(fields: [studentId], references: [id])
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])
  feeRefunds     FeeRefund[]

  @@index([schoolId])
  @@index([studentId])
  @@index([invoiceId])
  @@index([receiptNo])
  @@index([status])
  @@index([paidAt])
}

model PaymentProviderConfig {
  id            String   @id @default(uuid())
  tenantId      String
  provider      String
  apiKey        String
  secretKey     String
  callbackUrl   String?
  webhookSecret String?
  isActive      Boolean  @default(true)
  extraConfig   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([provider])
}

model WebhookLog {
  id          String    @id @default(uuid())
  tenantId    String?
  provider    String
  event       String?
  payload     Json
  headers     Json?
  signature   String?
  ipAddress   String?
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([provider])
  @@index([processed])
  @@index([createdAt])
}

model WebhookEmission {
  id          String   @id @default(uuid())
  tenantId    String?
  target      String
  eventType   String?
  eventId     String   @unique
  payload     Json
  signature   String?
  success     Boolean  @default(false)
  error       String?
  attempts    Int      @default(1)
  lastAttempt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([target])
  @@index([eventType])
  @@index([success])
  @@index([createdAt])
}

model LateFeesConfig {
  id             String   @id @default(uuid())
  schoolId       String   @unique
  tenantId       String?
  penaltyType    String
  penaltyAmount  Decimal  @db.Decimal(12, 2)
  graceDays      Int      @default(7)
  maxPenalty     Decimal? @db.Decimal(12, 2)
  applyRecurring Boolean  @default(false)
  recurrenceDays Int?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([schoolId])
}

model PaymentPlan {
  id           String                   @id @default(uuid())
  invoiceId    String                   @unique
  totalAmount  Decimal                  @db.Decimal(12, 2)
  installments Int
  frequency    String
  firstDueDate DateTime
  notes        String?
  isActive     Boolean                  @default(true)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  invoice      FeeInvoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  schedule     PaymentPlanInstallment[]

  @@index([invoiceId])
}

model PaymentPlanInstallment {
  id            String      @id @default(uuid())
  planId        String
  installmentNo Int
  dueDate       DateTime
  amount        Decimal     @db.Decimal(12, 2)
  status        String      @default("PENDING")
  paidAmount    Decimal?    @db.Decimal(12, 2)
  paidAt        DateTime?
  paymentId     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  plan          PaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, installmentNo])
  @@index([planId])
  @@index([status])
  @@index([dueDate])
}

model FeeRefund {
  id               String        @id @default(uuid())
  tenantId         String
  paymentId        String
  invoiceId        String
  studentId        String
  schoolId         String
  amount           Decimal       @db.Decimal(12, 2)
  reason           String
  status           String        @default("PENDING")
  paymentMethod    PaymentMethod
  providerRefundId String?
  initiatedBy      String
  completedAt      DateTime?
  errorMessage     String?
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  initiator        User          @relation(fields: [initiatedBy], references: [id])
  invoice          FeeInvoice    @relation(fields: [invoiceId], references: [id])
  payment          FeePayment    @relation(fields: [paymentId], references: [id])
  school           School        @relation(fields: [schoolId], references: [id])
  student          Student       @relation(fields: [studentId], references: [id])
  tenant           Tenant        @relation(fields: [tenantId], references: [id])

  @@index([paymentId])
  @@index([invoiceId])
  @@index([schoolId])
  @@index([status])
  @@index([createdAt])
}

model PaymentReminder {
  id               String     @id @default(uuid())
  invoiceId        String
  reminderType     String
  method           String
  recipientId      String?
  recipientContact String?
  status           String     @default("PENDING")
  sentAt           DateTime?
  errorMessage     String?
  createdAt        DateTime   @default(now())
  invoice          FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
  @@index([reminderType])
  @@index([createdAt])
}

